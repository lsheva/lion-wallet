{
  "name": "safari-evm-wallet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit && vite build",
    "typecheck": "tsgo --noEmit",
    "build:ext": "node --experimental-strip-types scripts/build.ts",
    "build:safari": "pnpm build:ext && xcodebuild -project xcode/SafariEVMWallet/SafariEVMWallet.xcodeproj -scheme SafariEVMWallet -configuration Debug build",
    "run:safari": "pnpm build:safari && open \"$(xcodebuild -project xcode/SafariEVMWallet/SafariEVMWallet.xcodeproj -scheme SafariEVMWallet -configuration Debug -showBuildSettings 2>/dev/null | grep ' BUILT_PRODUCTS_DIR' | awk '{print $3}')/SafariEVMWallet.app\"",
    "icons": "node --experimental-strip-types scripts/icons.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@preact/signals": "^2.8.2",
    "lucide-preact": "^0.577.0",
    "preact": "^10.29.0",
    "preact-router": "^4.1.2",
    "qrcode": "^1.5.4",
    "viem": "^2.47.5",
    "webextension-polyfill": "^0.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/qrcode": "^1.5.6",
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "esbuild": "^0.27.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
